<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- Header + TabLayout — always visible -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/lightPurple"
        android:paddingHorizontal="10dp"
        android:paddingTop="50dp"
        android:paddingBottom="0dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/studyHub"
            android:textSize="24sp"
            android:textColor="@color/darkPurple"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <com.google.android.material.tabs.TabLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:id="@+id/tabLayout"
            app:tabTextColor="@color/darkPurple"
            app:tabSelectedTextColor="@color/darkPurple"
            app:tabIndicatorColor="@color/peach"/>

    </LinearLayout>

    <!-- ViewPager2: shown on main tabs -->
    <androidx.viewpager2.widget.ViewPager2
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:id="@+id/viewPager"
        android:layout_weight="1"/>

    <!-- Fragment container: shown when navigating into Folders / Notes.
         Uses layout_weight so it fills the remaining screen below the header. -->
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:visibility="gone"/>

</LinearLayout>